{
  "info": {
    "_postman_id": "inkumanga-collection-v1",
    "name": "InkuManga API",
    "description": "Colección de endpoints para la API REST InkuManga — mangas, autores, usuarios, reseñas y Jikan.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Mangas",
      "item": [
        {
          "name": "Listar todos los mangas",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/mangas"
          }
        },
        {
          "name": "Buscar manga por ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/mangas/1"
          }
        },
        {
          "name": "Mangas con Autor (DTO)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/mangas/con-autor"
          }
        },
        {
          "name": "Agregar manga",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/mangas",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre_manga\": \"Berserk\",\n  \"genero\": \"Dark Fantasy\",\n  \"editorial\": \"Hakusensha\",\n  \"resumen\": \"La historia de Guts, un guerrero solitario en un mundo oscuro y brutal.\"\n}"
            }
          }
        },
        {
          "name": "Actualizar manga",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/mangas/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre_manga\": \"Berserk (Edición Deluxe)\",\n  \"genero\": \"Dark Fantasy\",\n  \"editorial\": \"Hakusensha\",\n  \"resumen\": \"Edición actualizada de Berserk.\"\n}"
            }
          }
        },
        {
          "name": "Eliminar manga",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/mangas/1"
          }
        }
      ]
    },
    {
      "name": "Autores",
      "item": [
        {
          "name": "Listar todos los autores",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/autores"
          }
        },
        {
          "name": "Buscar autor por ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/autores/1"
          }
        },
        {
          "name": "Agregar autor",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/autores",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre_au\": \"Kentaro Miura\",\n  \"fecha_nac_au\": \"1966-07-11\"\n}"
            }
          }
        },
        {
          "name": "Actualizar autor",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/autores/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre_au\": \"Kentaro Miura (actualizado)\",\n  \"fecha_nac_au\": \"1966-07-11\"\n}"
            }
          }
        },
        {
          "name": "Eliminar autor",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/autores/1"
          }
        }
      ]
    },
    {
      "name": "Usuarios",
      "item": [
        {
          "name": "Listar todos los usuarios",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/usuarios"
          }
        },
        {
          "name": "Buscar usuario por ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/usuarios/1"
          }
        },
        {
          "name": "Agregar usuario",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/usuarios",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre_us\": \"Ana García\",\n  \"correo\": \"ana.garcia@duoc.cl\",\n  \"fecha_nac_us\": 2000\n}"
            }
          }
        },
        {
          "name": "Actualizar usuario",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/usuarios/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre_us\": \"Ana García (actualizado)\",\n  \"correo\": \"ana.nueva@duoc.cl\",\n  \"fecha_nac_us\": 2000\n}"
            }
          }
        },
        {
          "name": "Eliminar usuario",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/usuarios/1"
          }
        }
      ]
    },
    {
      "name": "Reseñas",
      "item": [
        {
          "name": "Listar todas las reseñas",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/resenas"
          }
        },
        {
          "name": "Buscar reseña por ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/resenas/1"
          }
        },
        {
          "name": "Agregar reseña",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/resenas",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"comentario\": \"Una obra maestra del manga oscuro.\",\n  \"calificacion\": 5,\n  \"fecha_re\": \"2024-06-01\"\n}"
            }
          }
        },
        {
          "name": "Actualizar reseña",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/resenas/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"comentario\": \"Reseña actualizada: increíble narrativa.\",\n  \"calificacion\": 5,\n  \"fecha_re\": \"2024-06-15\"\n}"
            }
          }
        },
        {
          "name": "Eliminar reseña",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/resenas/1"
          }
        }
      ]
    },
    {
      "name": "Jikan API",
      "item": [
        {
          "name": "Obtener manga por ID (Monster = 1, Berserk = 2)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/jikan/manga/2"
          }
        },
        {
          "name": "Buscar manga por nombre",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/jikan/manga/buscar?q=berserk",
              "query": [{ "key": "q", "value": "berserk" }]
            }
          }
        }
      ]
    }
  ]
}
